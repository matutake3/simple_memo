<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ============================================================
         Notifications (Android 13+) — チェックリストのロック画面通知
         ============================================================ -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- ============================================================
         Biometric / device credential (プライバシーロック)
         ============================================================ -->
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />

    <!-- ============================================================
         Boot completed (ウィジェットの再表示 / 通知の復帰)
         ============================================================ -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- ============================================================
         Billing
         ============================================================ -->
    <uses-permission android:name="com.android.vending.BILLING" />

    <!-- ============================================================
         Backup ファイル選択 (SAF) は Manifest 宣言不要
         ============================================================ -->

    <application
        android:name=".App"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SimpleMemo"
        tools:targetApi="34">

        <!-- ============================================================
             Activities
             ============================================================ -->
        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.EditMemoActivity"
            android:exported="false"
            android:parentActivityName=".ui.MainActivity"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.EditChecklistActivity"
            android:exported="false"
            android:parentActivityName=".ui.MainActivity"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".search.SearchActivity"
            android:exported="false"
            android:parentActivityName=".ui.MainActivity"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.SettingsActivity"
            android:exported="false"
            android:parentActivityName=".ui.MainActivity" />

        <activity
            android:name=".ui.TagManagerActivity"
            android:exported="false"
            android:parentActivityName=".ui.SettingsActivity" />

        <activity
            android:name=".ui.TemplateManagerActivity"
            android:exported="false"
            android:parentActivityName=".ui.SettingsActivity" />

        <activity
            android:name=".ui.TrashActivity"
            android:exported="false"
            android:parentActivityName=".ui.SettingsActivity" />

        <activity
            android:name=".backup.BackupActivity"
            android:exported="false"
            android:parentActivityName=".ui.SettingsActivity" />

        <activity
            android:name=".ui.OnboardingActivity"
            android:exported="false" />

        <activity
            android:name=".ui.UsageGuideActivity"
            android:exported="false"
            android:parentActivityName=".ui.SettingsActivity" />

        <activity
            android:name=".ui.FaqActivity"
            android:exported="false"
            android:parentActivityName=".ui.SettingsActivity" />

        <!-- ============================================================
             Widgets (テキストメモ / チェックリスト)
             ============================================================ -->
        <receiver
            android:name=".widget.TextMemoWidgetProvider"
            android:exported="false"
            android:label="シンプルメモ帳: テキスト">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_text_memo_info" />
        </receiver>

        <receiver
            android:name=".widget.ChecklistWidgetProvider"
            android:exported="false"
            android:label="シンプルメモ帳: リスト">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_checklist_info" />
        </receiver>

        <service
            android:name=".widget.ChecklistRemoteViewsService"
            android:permission="android.permission.BIND_REMOTEVIEWS"
            android:exported="false" />

        <receiver
            android:name=".widget.ChecklistToggleReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="jp.simplist.memo.widget.action.TOGGLE_CHECK" />
            </intent-filter>
        </receiver>

        <!-- 設定 Activity: OS が直接起動するため exported=true 必須 -->
        <activity
            android:name=".widget.TextMemoConfigActivity"
            android:exported="true"
            android:theme="@style/Theme.SimpleMemo"
            android:label="テキストメモを選択">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_CONFIGURE" />
            </intent-filter>
        </activity>

        <activity
            android:name=".widget.ChecklistConfigActivity"
            android:exported="true"
            android:theme="@style/Theme.SimpleMemo"
            android:label="リストを選択">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_CONFIGURE" />
            </intent-filter>
        </activity>

        <!-- ウィジェット「項目を追加」行から開くクイック追加 (浮動ダイアログ)。
             taskAffinity を空にして本体メインタスクと切り離し、メイン画面が背後に出ないようにする。 -->
        <activity
            android:name=".widget.QuickAddItemActivity"
            android:exported="false"
            android:theme="@style/Theme.SimpleMemo.QuickAdd"
            android:excludeFromRecents="true"
            android:taskAffinity=""
            android:launchMode="singleInstance" />

        <!-- ============================================================
             Downloadable Fonts (Inter family)
             ============================================================ -->
        <meta-data
            android:name="preloaded_fonts"
            android:resource="@array/preloaded_fonts" />

    </application>

</manifest>
