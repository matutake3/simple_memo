<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_widget_header_3"
            android:paddingHorizontal="12dp"
            android:paddingVertical="8dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="買い物リスト"
                android:textSize="13sp"
                android:fontFamily="@font/inter_medium"
                android:textColor="@color/ink" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/bg_widget_body_3"
            android:paddingHorizontal="10dp"
            android:paddingVertical="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingVertical="2dp">
                <ImageView android:layout_width="16dp" android:layout_height="16dp"
                    android:src="@drawable/ic_check_box" android:layout_gravity="center_vertical" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginStart="8dp" android:text="卵" android:textSize="12sp"
                    android:textColor="@color/ink" android:layout_gravity="center_vertical" />
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingVertical="2dp">
                <ImageView android:layout_width="16dp" android:layout_height="16dp"
                    android:src="@drawable/ic_check_box" android:layout_gravity="center_vertical" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginStart="8dp" android:text="牛乳" android:textSize="12sp"
                    android:textColor="@color/ink" android:layout_gravity="center_vertical" />
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingVertical="2dp">
                <ImageView android:layout_width="16dp" android:layout_height="16dp"
                    android:src="@drawable/ic_check_box_filled" android:layout_gravity="center_vertical" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginStart="8dp" android:text="パン" android:textSize="12sp"
                    android:textColor="@color/graphite_dim" android:layout_gravity="center_vertical" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
