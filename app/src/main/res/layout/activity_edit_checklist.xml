<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?android:attr/colorBackground">

    <!-- Toolbar: 戻るのみ。各種アクションはフッターに集約。 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/toolbar_height"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="@dimen/toolbar_padding_h"
        android:paddingEnd="@dimen/toolbar_padding_h">

        <ImageButton android:id="@+id/backButton" android:layout_width="40dp" android:layout_height="40dp"
            android:src="@drawable/ic_arrow_back" android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/ink_secondary" android:contentDescription="@string/action_back" />
    </LinearLayout>

    <View style="@style/HairLine" android:background="?attr/colorHair" />

    <FrameLayout
        android:id="@+id/titleBlock"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="@dimen/screen_padding_horizontal"
        android:paddingEnd="@dimen/screen_padding_horizontal"
        android:paddingTop="16dp"
        android:paddingBottom="16dp">

        <EditText
            android:id="@+id/titleEdit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_title"
            android:textSize="18sp"
            android:fontFamily="@font/inter_medium"
            android:textColor="?android:attr/textColorPrimary"
            android:textColorHint="@color/graphite"
            android:background="@null"
            android:singleLine="true"
            android:inputType="text"
            android:imeOptions="actionNext" />
    </FrameLayout>

    <View style="@style/HairLine" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/itemList"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:clipChildren="false"
            android:paddingTop="4dp"
            android:paddingBottom="4dp" />

        <FrameLayout
            android:id="@+id/emptyTapZone"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone"
            android:background="?attr/selectableItemBackground">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="タップして項目を追加"
                android:textColor="@color/graphite_dim"
                android:textSize="14sp"
                android:fontFamily="@font/inter_regular" />
        </FrameLayout>
    </FrameLayout>

    <!-- 入力候補チップ行: 過去のチェックリスト全体で頻出した項目を表示。
         タップで末尾追加 / 長押しで「候補から除外」リストへ追加。
         ChipGroup は内部 FlowLayout で行末折り返しを自動処理。 -->
    <LinearLayout
        android:id="@+id/suggestionContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/suggestionLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="@dimen/screen_padding_horizontal"
            android:paddingTop="6dp"
            android:paddingBottom="2dp"
            android:textSize="11sp"
            android:textColor="@color/graphite"
            android:fontFamily="@font/inter_regular"
            android:text="よく使う項目" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/suggestionRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="@dimen/screen_padding_horizontal"
            android:paddingEnd="@dimen/screen_padding_horizontal"
            android:paddingTop="2dp"
            android:paddingBottom="6dp"
            app:chipSpacingHorizontal="6dp"
            app:chipSpacingVertical="4dp" />
    </LinearLayout>

    <!-- 完了済みを削除 (チェックリスト固有)。HairLine の上に中央寄せで配置。 -->
    <TextView
        android:id="@+id/deleteCheckedButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="6dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:text="@string/delete_completed"
        android:textColor="@color/accent_sage_dark"
        android:fontFamily="@font/inter_medium"
        android:textSize="13sp"
        android:background="?attr/selectableItemBackground" />

    <View style="@style/HairLine" />

    <!-- Footer: 6 アイコン (色 / 重要度 / タグ / 共有 / 保護 / 削除) を等幅で並べる。 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="@dimen/screen_padding_horizontal"
        android:paddingEnd="@dimen/screen_padding_horizontal"
        android:paddingTop="4dp"
        android:paddingBottom="14dp">

        <ImageButton android:id="@+id/colorButton" android:layout_width="0dp" android:layout_height="44dp"
            android:layout_weight="1" android:src="@drawable/ic_palette"
            android:background="?attr/selectableItemBackgroundBorderless" app:tint="?attr/iconTintPalette"
            android:contentDescription="@string/action_color" />

        <ImageButton android:id="@+id/priorityButton" android:layout_width="0dp" android:layout_height="44dp"
            android:layout_weight="1" android:src="@drawable/ic_star_outline"
            android:background="?attr/selectableItemBackgroundBorderless" app:tint="?attr/iconTintPriority"
            android:contentDescription="@string/action_priority" />

        <ImageButton android:id="@+id/tagButton" android:layout_width="0dp" android:layout_height="44dp"
            android:layout_weight="1" android:src="@drawable/ic_label_outline"
            android:background="?attr/selectableItemBackgroundBorderless" app:tint="?attr/iconTintTag"
            android:contentDescription="@string/action_tag" />

        <ImageButton android:id="@+id/shareButton" android:layout_width="0dp" android:layout_height="44dp"
            android:layout_weight="1" android:src="@drawable/ic_share"
            android:background="?attr/selectableItemBackgroundBorderless" app:tint="?attr/iconTintShare"
            android:contentDescription="@string/action_share" />

        <ImageButton android:id="@+id/protectButton" android:layout_width="0dp" android:layout_height="44dp"
            android:layout_weight="1" android:src="@drawable/ic_lock_open"
            android:background="?attr/selectableItemBackgroundBorderless" app:tint="?attr/iconTintProtect"
            android:contentDescription="@string/action_protect" />

        <ImageButton android:id="@+id/deleteButton" android:layout_width="0dp" android:layout_height="44dp"
            android:layout_weight="1" android:src="@drawable/ic_delete"
            android:background="?attr/selectableItemBackgroundBorderless" app:tint="?attr/iconTintDelete"
            android:contentDescription="@string/action_delete" />
    </LinearLayout>
</LinearLayout>
