<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Toolbar 領域: 通常モードと複数選択モードを切替 -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/toolbar_height"
            android:background="?android:attr/colorBackground">

            <!-- 通常モードのツールバー -->
            <LinearLayout
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="@dimen/toolbar_padding_h"
                android:paddingEnd="@dimen/toolbar_padding_h">

                <ImageButton
                    android:id="@+id/menuButton"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_menu"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="?android:attr/textColorPrimary"
                    android:contentDescription="@string/action_menu" />

                <TextView
                    android:id="@+id/toolbarTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="@string/title_main"
                    style="@style/Text.H1"
                    android:textSize="17sp"
                    android:singleLine="true"
                    android:ellipsize="end" />

                <ImageButton
                    android:id="@+id/sortButton"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_sort"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="?android:attr/textColorPrimary"
                    android:contentDescription="@string/action_sort" />

                <TextView
                    android:id="@+id/sortDoneButton"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:gravity="center"
                    android:paddingHorizontal="12dp"
                    android:text="@string/action_done"
                    style="@style/Text.Button"
                    android:textColor="@color/accent_sage_dark"
                    android:background="?attr/selectableItemBackground"
                    android:visibility="gone"
                    tools:visibility="visible" />

                <ImageButton
                    android:id="@+id/searchButton"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_search"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="?android:attr/textColorPrimary"
                    android:contentDescription="@string/action_search" />

                <ImageButton
                    android:id="@+id/moreButton"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_more_vert"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="?android:attr/textColorPrimary"
                    android:contentDescription="@string/action_more" />
            </LinearLayout>

            <!-- 複数選択モードのトップバー: 閉じる + 件数表示のみ。各アクションはフッターに配置。 -->
            <LinearLayout
                android:id="@+id/multiSelectToolbar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="@dimen/toolbar_padding_h"
                android:paddingEnd="@dimen/toolbar_padding_h"
                android:visibility="gone"
                tools:visibility="visible">

                <ImageButton
                    android:id="@+id/msCloseButton"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_close"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="?android:attr/textColorPrimary"
                    android:contentDescription="@string/action_close" />

                <TextView
                    android:id="@+id/msCountText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    style="@style/Text.H1"
                    android:textSize="17sp"
                    android:singleLine="true"
                    tools:text="3 件選択" />
            </LinearLayout>
        </FrameLayout>

        <View style="@style/HairLine" android:background="?attr/colorHair" />

        <!-- Tag filter row -->
        <HorizontalScrollView
            android:id="@+id/tagFilterScroll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:overScrollMode="never"
            android:fillViewport="false"
            android:background="?android:attr/colorBackground">

            <LinearLayout
                android:id="@+id/tagFilterRow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:paddingStart="@dimen/screen_padding_horizontal"
                android:paddingEnd="@dimen/screen_padding_horizontal"
                android:gravity="center_vertical" />
        </HorizontalScrollView>

        <!-- Memo list -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/memoList"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingTop="4dp"
                android:paddingBottom="120dp"
                android:scrollbars="none"
                tools:listitem="@layout/item_memo_card" />

            <!-- Empty state -->
            <LinearLayout
                android:id="@+id/emptyState"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="gone"
                tools:visibility="visible">

                <ImageView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:src="@drawable/ic_note_add"
                    app:tint="@color/graphite_dim"
                    android:contentDescription="@null" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/empty_main_title"
                    style="@style/Text.H2"
                    android:textColor="@color/ink_secondary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/empty_main_desc"
                    style="@style/Text.Body.Sub"
                    android:gravity="center" />
            </LinearLayout>
        </FrameLayout>

        <!-- 複数選択モード時のフッター: タグ / 保護 / 複製 / 全選択 / 削除 を等幅。 -->
        <LinearLayout
            android:id="@+id/multiSelectFooter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            tools:visibility="visible">

            <View style="@style/HairLine" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="@dimen/screen_padding_horizontal"
                android:paddingEnd="@dimen/screen_padding_horizontal"
                android:paddingTop="8dp"
                android:paddingBottom="14dp">

                <ImageButton
                    android:id="@+id/msTagButton"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:src="@drawable/ic_label_outline"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="?attr/iconTintTag"
                    android:contentDescription="@string/action_tag" />

                <ImageButton
                    android:id="@+id/msProtectButton"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:src="@drawable/ic_lock_open"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="?attr/iconTintProtect"
                    android:contentDescription="@string/action_protect" />

                <ImageButton
                    android:id="@+id/msDuplicateButton"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:src="@drawable/ic_copy"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="@color/ink_secondary"
                    android:contentDescription="@string/multi_duplicate" />

                <ImageButton
                    android:id="@+id/msSelectAllButton"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:src="@drawable/ic_select_all"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="@color/ink_secondary"
                    android:contentDescription="@string/multi_select_all" />

                <ImageButton
                    android:id="@+id/msDeleteButton"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:src="@drawable/ic_delete"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="?attr/iconTintDelete"
                    android:contentDescription="@string/action_delete" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- FAB pair (memo + list) -->
    <LinearLayout
        android:id="@+id/fabContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="@dimen/fab_margin"
        android:layout_marginBottom="@dimen/fab_margin"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <FrameLayout
            android:id="@+id/fabMemo"
            android:layout_width="@dimen/fab_size"
            android:layout_height="@dimen/fab_size"
            android:background="?attr/bgFabMemo"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="@string/fab_memo">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:gravity="center">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_pencil"
                    app:tint="@android:color/white"
                    android:contentDescription="@null" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/fab_memo"
                    android:textSize="11sp"
                    android:textColor="@android:color/white"
                    android:fontFamily="@font/inter_medium"
                    android:includeFontPadding="false" />
            </LinearLayout>
        </FrameLayout>

        <Space
            android:layout_width="@dimen/fab_gap"
            android:layout_height="0dp" />

        <FrameLayout
            android:id="@+id/fabList"
            android:layout_width="@dimen/fab_size"
            android:layout_height="@dimen/fab_size"
            android:background="?attr/bgFabList"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="@string/fab_list">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:gravity="center">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_check_square"
                    app:tint="@android:color/white"
                    android:contentDescription="@null" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/fab_list"
                    android:textSize="11sp"
                    android:textColor="@android:color/white"
                    android:fontFamily="@font/inter_medium"
                    android:includeFontPadding="false" />
            </LinearLayout>
        </FrameLayout>
    </LinearLayout>

    <!--
      プライバシーロック認証中のコンテンツ目隠しオーバーレイ。
      MainActivity.onCreate で「認証必要」と判定された時だけ visibility を VISIBLE に。
      認証成功 → onUnlocked で GONE。これによりメモ一覧が背後に透けて見えるのを防ぐ。
      CoordinatorLayout の最後の子なので z-order 上は最前面に描画される。
    -->
    <FrameLayout
        android:id="@+id/lockOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?android:attr/colorBackground"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone"
        tools:visibility="visible">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:src="@drawable/ic_lock"
                app:tint="@color/accent_sage_dark"
                android:contentDescription="@null" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                style="@style/Text.Body.Sub"
                android:text="@string/privacy_lock_subtitle" />
        </LinearLayout>
    </FrameLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
