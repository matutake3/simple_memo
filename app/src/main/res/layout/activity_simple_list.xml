<?xml version="1.0" encoding="utf-8"?>
<!--
  シンプルなツールバー + RecyclerView の汎用 layout。
  Tag manager / Template manager / Trash で共有。
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?android:attr/colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/toolbar_height"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="@dimen/toolbar_padding_h"
        android:paddingEnd="@dimen/toolbar_padding_h">
        <ImageButton android:id="@+id/backButton" android:layout_width="40dp" android:layout_height="40dp"
            android:src="@drawable/ic_arrow_back" android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="?android:attr/textColorPrimary" android:contentDescription="@string/action_back" />
        <TextView android:id="@+id/toolbarTitle" android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp" style="@style/Text.H1"
            tools:text="タグ管理" />
        <ImageButton android:id="@+id/moreButton" android:layout_width="40dp" android:layout_height="40dp"
            android:src="@drawable/ic_more_vert" android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="?android:attr/textColorPrimary" android:contentDescription="@string/action_more" android:visibility="gone" />
    </LinearLayout>

    <View style="@style/HairLine" android:background="?attr/colorHair" />

    <TextView
        android:id="@+id/headerNote"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:paddingStart="@dimen/screen_padding_horizontal"
        android:paddingEnd="@dimen/screen_padding_horizontal"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:background="@color/paper_dim"
        style="@style/Text.Body.Sub"
        tools:visibility="visible"
        tools:text="7日間経過したメモは自動的に完全削除されます" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingTop="4dp"
            android:paddingBottom="80dp" />

        <TextView
            android:id="@+id/emptyText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone"
            style="@style/Text.Body.Sub"
            tools:visibility="visible"
            tools:text="まだ登録されていません" />
    </FrameLayout>

    <LinearLayout
        android:id="@+id/addRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="@dimen/screen_padding_horizontal"
        android:paddingEnd="@dimen/screen_padding_horizontal"
        android:paddingTop="16dp"
        android:paddingBottom="16dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true">

        <ImageView android:layout_width="20dp" android:layout_height="20dp"
            android:src="@drawable/ic_add" app:tint="@color/accent_sage_dark"
            android:contentDescription="@null" />
        <TextView android:id="@+id/addRowText"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:textColor="@color/accent_sage_dark"
            android:textSize="14sp"
            android:fontFamily="@font/inter_medium"
            tools:text="新しいタグを追加" />
    </LinearLayout>
</LinearLayout>
