<?xml version="1.0" encoding="utf-8"?>
<!--
  ウィジェット設定 Activity 内のメモ選択行。メモカードと似た見た目だが少し小さめ。
  背景色はメモのカラーから動的に。
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="12dp"
    android:layout_marginEnd="12dp"
    android:layout_marginTop="@dimen/card_gap"
    android:background="?attr/bgMemoCard"
    android:backgroundTint="@color/color_default"
    android:paddingStart="@dimen/card_padding_h"
    android:paddingEnd="@dimen/card_padding_h"
    android:paddingTop="@dimen/card_padding_v"
    android:paddingBottom="@dimen/card_padding_v"
    android:minHeight="48dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <ImageView
        android:id="@+id/typeIcon"
        android:layout_width="20dp"
        android:layout_height="20dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:src="@drawable/ic_note"
        app:tint="?android:attr/textColorPrimary"
        android:contentDescription="@null" />

    <TextView
        android:id="@+id/title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        app:layout_constraintStart_toEndOf="@id/typeIcon"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        style="@style/Text.Body.Large"
        android:singleLine="true"
        android:ellipsize="end"
        tools:text="来週のプレゼン資料準備" />
</androidx.constraintlayout.widget.ConstraintLayout>
