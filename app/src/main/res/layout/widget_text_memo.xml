<?xml version="1.0" encoding="utf-8"?>
<!--
  テキストメモウィジェットのルートレイアウト。
  RemoteViews 制約のため LinearLayout / FrameLayout のみ使用。
  背景色: header (濃) + body (淡) の 2 段構成。
   - widgetHeader → bg_widget_header_N (上のみ角丸 + フルカラー)
   - widgetBody   → bg_widget_body_N   (下のみ角丸 + 同系淡色)
   - widgetRoot   → 透過 (clip 用に下角丸の bg_widget_card_N を保持)
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widgetRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_widget_card_default">

    <LinearLayout
        android:id="@+id/widgetContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <FrameLayout
            android:id="@+id/widgetHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_widget_header_default"
            android:paddingHorizontal="14dp"
            android:paddingVertical="10dp">

            <TextView
                android:id="@+id/widgetTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:fontFamily="@font/inter_medium"
                android:textColor="@color/ink"
                android:singleLine="true"
                android:ellipsize="end" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/widgetBody"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@drawable/bg_widget_body_default"
            android:paddingHorizontal="14dp"
            android:paddingVertical="10dp">

            <TextView
                android:id="@+id/widgetBodyText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:fontFamily="@font/inter_regular"
                android:textColor="@color/ink_secondary"
                android:lineSpacingMultiplier="1.3"
                android:ellipsize="end"
                android:maxLines="30" />
        </FrameLayout>
    </LinearLayout>

    <!-- メモ削除時の状態表示。タップで設定 Activity を再起動。 -->
    <LinearLayout
        android:id="@+id/widgetEmpty"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="14dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="メモが削除されました"
            android:textSize="13sp"
            android:fontFamily="@font/inter_medium"
            android:textColor="@color/ink_secondary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="タップして別のメモを選択"
            android:textSize="11sp"
            android:fontFamily="@font/inter_regular"
            android:textColor="@color/graphite" />
    </LinearLayout>
</FrameLayout>
