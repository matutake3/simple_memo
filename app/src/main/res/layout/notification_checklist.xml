<?xml version="1.0" encoding="utf-8"?>
<!--
  ロック画面 / 通知シェードに常駐するチェックリスト通知の expanded view。
  RemoteViews 制約のため LinearLayout / FrameLayout / ImageView / TextView のみ使用。
  項目は固定 8 スロット (notifRow0..notifRow7) + あふれた分は notifOverflow に件数表示。
  各行タップで ChecklistToggleReceiver にイベント送信 → DB 更新 → 通知再 post。
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="14dp"
    android:paddingEnd="14dp"
    android:paddingTop="6dp"
    android:paddingBottom="10dp">

    <TextView
        android:id="@+id/notifTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:textStyle="bold"
        android:singleLine="true"
        android:ellipsize="end"
        android:layout_marginBottom="4dp" />

    <LinearLayout android:id="@+id/notifRow0"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingTop="3dp" android:paddingBottom="3dp">
        <ImageView android:id="@+id/notifRow0Check"
            android:layout_width="18dp" android:layout_height="18dp"
            android:contentDescription="@null" />
        <TextView android:id="@+id/notifRow0Text"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginStart="10dp" android:textSize="13sp"
            android:singleLine="true" android:ellipsize="end" />
    </LinearLayout>

    <LinearLayout android:id="@+id/notifRow1"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingTop="3dp" android:paddingBottom="3dp">
        <ImageView android:id="@+id/notifRow1Check"
            android:layout_width="18dp" android:layout_height="18dp"
            android:contentDescription="@null" />
        <TextView android:id="@+id/notifRow1Text"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginStart="10dp" android:textSize="13sp"
            android:singleLine="true" android:ellipsize="end" />
    </LinearLayout>

    <LinearLayout android:id="@+id/notifRow2"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingTop="3dp" android:paddingBottom="3dp">
        <ImageView android:id="@+id/notifRow2Check"
            android:layout_width="18dp" android:layout_height="18dp"
            android:contentDescription="@null" />
        <TextView android:id="@+id/notifRow2Text"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginStart="10dp" android:textSize="13sp"
            android:singleLine="true" android:ellipsize="end" />
    </LinearLayout>

    <LinearLayout android:id="@+id/notifRow3"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingTop="3dp" android:paddingBottom="3dp">
        <ImageView android:id="@+id/notifRow3Check"
            android:layout_width="18dp" android:layout_height="18dp"
            android:contentDescription="@null" />
        <TextView android:id="@+id/notifRow3Text"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginStart="10dp" android:textSize="13sp"
            android:singleLine="true" android:ellipsize="end" />
    </LinearLayout>

    <LinearLayout android:id="@+id/notifRow4"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingTop="3dp" android:paddingBottom="3dp">
        <ImageView android:id="@+id/notifRow4Check"
            android:layout_width="18dp" android:layout_height="18dp"
            android:contentDescription="@null" />
        <TextView android:id="@+id/notifRow4Text"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginStart="10dp" android:textSize="13sp"
            android:singleLine="true" android:ellipsize="end" />
    </LinearLayout>

    <LinearLayout android:id="@+id/notifRow5"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingTop="3dp" android:paddingBottom="3dp">
        <ImageView android:id="@+id/notifRow5Check"
            android:layout_width="18dp" android:layout_height="18dp"
            android:contentDescription="@null" />
        <TextView android:id="@+id/notifRow5Text"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginStart="10dp" android:textSize="13sp"
            android:singleLine="true" android:ellipsize="end" />
    </LinearLayout>

    <LinearLayout android:id="@+id/notifRow6"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingTop="3dp" android:paddingBottom="3dp">
        <ImageView android:id="@+id/notifRow6Check"
            android:layout_width="18dp" android:layout_height="18dp"
            android:contentDescription="@null" />
        <TextView android:id="@+id/notifRow6Text"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginStart="10dp" android:textSize="13sp"
            android:singleLine="true" android:ellipsize="end" />
    </LinearLayout>

    <LinearLayout android:id="@+id/notifRow7"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingTop="3dp" android:paddingBottom="3dp">
        <ImageView android:id="@+id/notifRow7Check"
            android:layout_width="18dp" android:layout_height="18dp"
            android:contentDescription="@null" />
        <TextView android:id="@+id/notifRow7Text"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginStart="10dp" android:textSize="13sp"
            android:singleLine="true" android:ellipsize="end" />
    </LinearLayout>

    <TextView android:id="@+id/notifOverflow"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textSize="12sp"
        android:visibility="gone"
        android:alpha="0.6" />
</LinearLayout>
