<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?android:attr/colorBackground">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/screen_padding_horizontal"
            android:paddingEnd="@dimen/screen_padding_horizontal"
            android:paddingTop="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/title_onboarding"
                style="@style/Text.H1" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/onboarding_subtitle"
                style="@style/Text.Body.Sub" />

            <!-- Feature card: Widget -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="24dp"
                android:padding="16dp"
                android:background="?attr/bgCardSurface">
                <TextView style="@style/Text.Body.Large" android:text="@string/onboarding_widget_title"
                    android:layout_width="match_parent" android:layout_height="wrap_content" />
                <TextView style="@style/Text.Body.Sub" android:text="@string/onboarding_widget_desc"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- Permission card: Notifications -->
            <LinearLayout
                android:id="@+id/notifCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="12dp"
                android:padding="16dp"
                android:background="?attr/bgCardSurface">
                <TextView style="@style/Text.Body.Large" android:text="@string/onboarding_notification_title"
                    android:layout_width="match_parent" android:layout_height="wrap_content" />
                <TextView style="@style/Text.Body.Sub" android:text="@string/onboarding_notification_desc"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginTop="4dp" />
                <TextView
                    android:id="@+id/notifGrantButton"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:layout_marginTop="12dp"
                    android:layout_gravity="end"
                    android:gravity="center"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:text="@string/onboarding_grant"
                    style="@style/Text.Button"
                    android:textColor="?android:attr/textColorPrimary"
                    android:background="@drawable/bg_button_outlined" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <TextView
        android:id="@+id/startButton"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_margin="@dimen/screen_padding_horizontal"
        android:gravity="center"
        android:text="@string/onboarding_start"
        style="@style/Text.Button"
        android:textColor="@color/accent_sage_text"
        android:background="?attr/bgButtonPrimary" />
</LinearLayout>
