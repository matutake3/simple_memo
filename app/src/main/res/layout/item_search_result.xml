<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginStart="@dimen/screen_padding_horizontal"
    android:layout_marginEnd="@dimen/screen_padding_horizontal"
    android:layout_marginTop="@dimen/card_gap"
    android:background="@drawable/bg_memo_card"
    android:backgroundTint="@color/color_default"
    android:padding="@dimen/card_padding_v"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/typeIcon"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_note"
            app:tint="@color/ink"
            android:contentDescription="@null" />

        <TextView
            android:id="@+id/title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            style="@style/Text.Title.Card"
            android:singleLine="true"
            android:ellipsize="end"
            tools:text="来週のプレゼン資料準備" />
    </LinearLayout>

    <TextView
        android:id="@+id/snippet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:layout_marginStart="32dp"
        style="@style/Text.Body.Sub"
        tools:text="...グラフ追加、プレゼンで使うデータも..." />

    <TextView
        android:id="@+id/timestamp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:layout_marginTop="6dp"
        style="@style/Text.Caption"
        tools:text="今日 10:32" />
</LinearLayout>
