<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:minHeight="35dp"
    android:orientation="horizontal"
    android:paddingStart="12dp"
    android:paddingTop="0dp"
    android:paddingEnd="@dimen/screen_padding_horizontal"
    android:paddingBottom="0dp">

    <com.google.android.material.checkbox.MaterialCheckBox
        android:id="@+id/checkbox"
        style="@style/SimpleMemo.MaterialCheckBox"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingStart="0dp"
        android:paddingEnd="0dp"
        android:minWidth="0dp" />

    <jp.simplist.memo.ui.adapters.BackspaceAwareEditText
        android:id="@+id/itemEdit"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:layout_weight="1"
        android:background="@null"
        android:fontFamily="@font/inter_regular"
        android:imeOptions="actionNext"
        android:inputType="text|textCapSentences"
        android:singleLine="true"
        android:textColor="?android:attr/textColorPrimary"
        android:textColorHint="@color/graphite"
        android:textSize="14sp" />

    <ImageView
        android:id="@+id/dragHandle"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginStart="8dp"
        android:contentDescription="@null"
        android:src="@drawable/ic_drag_handle"
        app:tint="@color/graphite" />
</LinearLayout>
