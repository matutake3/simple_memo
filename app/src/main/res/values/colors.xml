<?xml version="1.0" encoding="utf-8"?>
<!--
  Simple Memo color palette (DESIGN_SPEC §3 / §12.1).
  シリーズ既存のモノトーン暗色パレットとは独立。クリーム地 + パステルパレット。
  values-night/colors.xml は同値の duplicate (本アプリは v1 ライト固定)。
-->
<resources>

