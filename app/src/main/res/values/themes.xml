<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!--
      Simple Memo は light-locked (v1).
      values-night/themes.xml も同値の duplicate にして実機で常にライト見え。
      DESIGN_SPEC §2.1 参照。
    -->
    <style name="Theme.SimpleMemo" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent_sage</item>
        <item name="colorOnPrimary">@color/accent_sage_text</item>
        <item name="colorSecondary">@color/accent_blue</item>
        <item name="colorOnSecondary">@color/ink</item>
        <item name="android:colorBackground">@color/paper</item>
        <item name="android:windowBackground">@color/paper</item>
        <item name="android:statusBarColor">@color/paper</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
        <item name="android:navigationBarColor">@color/paper</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">true</item>
        <item name="android:textColorPrimary">@color/ink</item>
        <item name="android:textColorSecondary">@color/ink_secondary</item>
        <item name="android:textColorHint">@color/graphite</item>
        <item name="android:fontFamily">@font/inter_regular</item>
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.SimpleMemo.Dialog</item>
        <item name="bottomSheetDialogTheme">@style/ThemeOverlay.SimpleMemo.BottomSheet</item>
        <item name="colorControlActivated">@color/accent_sage</item>
        <item name="colorControlNormal">@color/ink_secondary</item>
        <item name="colorOnSurface">@color/ink</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorHair">@color/hair_subtle</item>
        <!-- 標準: 角丸あり / マルチカラーアイコン -->
        <item name="bgMemoCard">@drawable/bg_memo_card</item>
        <item name="bgCardSurface">@drawable/bg_card_surface</item>
        <item name="bgButtonPrimary">@drawable/bg_button_primary</item>
        <item name="bgFabMemo">@drawable/bg_fab_memo</item>
        <item name="bgFabList">@drawable/bg_fab_list</item>
        <item name="bgChipFilterSelected">@drawable/bg_chip_filter_selected</item>
        <item name="bgChipFilterUnselected">@drawable/bg_chip_filter_unselected</item>
        <item name="bgChipTag">@drawable/bg_chip_tag</item>
        <item name="bgTagInitial">@drawable/bg_tag_initial</item>
        <item name="bgDialogSurface">@drawable/bg_dialog_surface</item>
        <item name="bgSearchField">@drawable/bg_search_field</item>
        <item name="iconTintPalette">@color/icon_palette</item>
        <item name="iconTintPriority">@color/icon_priority</item>
        <item name="iconTintTag">@color/icon_tag</item>
        <item name="iconTintShare">@color/icon_share</item>
        <item name="iconTintProtect">@color/icon_protect</item>
        <item name="iconTintDelete">@color/icon_delete</item>
        <!-- 色なしメモのタイプアイコン: リスト FAB と同色 (sage) -->
        <item name="iconTintDefault">@color/accent_sage</item>
    </style>

    <!--
      Stylish (無機質ノート風): 白地 + 直角 + モノトーンアイコン。
    -->
    <style name="Theme.SimpleMemo.Stylish" parent="Theme.SimpleMemo">
        <item name="android:colorBackground">@color/paper_stylish</item>
        <item name="android:windowBackground">@color/paper_stylish</item>
        <item name="android:statusBarColor">@color/paper_stylish</item>
        <item name="android:navigationBarColor">@color/paper_stylish</item>
        <item name="colorSurface">@color/paper_stylish</item>
        <item name="colorHair">@color/hair_stylish</item>
        <!-- 文字色を「黒に近いブルー」に。textColorPrimary を経由する箇所は自動追従。 -->
        <item name="android:textColorPrimary">@color/ink_stylish</item>
        <item name="colorOnSurface">@color/ink_stylish</item>
        <item name="colorControlNormal">@color/ink_secondary</item>
        <!-- スタイリッシュ: 角丸 0dp / モノトーンアイコン (ink で統一) -->
        <item name="bgMemoCard">@drawable/bg_memo_card_stylish</item>
        <item name="bgCardSurface">@drawable/bg_card_surface_stylish</item>
        <item name="bgButtonPrimary">@drawable/bg_button_primary_stylish</item>
        <item name="bgFabMemo">@drawable/bg_fab_memo_stylish</item>
        <item name="bgFabList">@drawable/bg_fab_list_stylish</item>
        <item name="bgChipFilterSelected">@drawable/bg_chip_filter_selected_stylish</item>
        <item name="bgChipFilterUnselected">@drawable/bg_chip_filter_unselected_stylish</item>
        <item name="bgChipTag">@drawable/bg_chip_tag_stylish</item>
        <item name="bgTagInitial">@drawable/bg_tag_initial_stylish</item>
        <item name="bgDialogSurface">@drawable/bg_dialog_surface_stylish</item>
        <item name="bgSearchField">@drawable/bg_search_field_stylish</item>
        <item name="iconTintPalette">@color/ink_stylish</item>
        <item name="iconTintPriority">@color/ink_stylish</item>
        <item name="iconTintTag">@color/ink_stylish</item>
        <item name="iconTintShare">@color/ink_stylish</item>
        <item name="iconTintProtect">@color/ink_stylish</item>
        <item name="iconTintDelete">@color/ink_stylish</item>
        <!-- 色なしメモのタイプアイコン: スタイリッシュではリスト FAB (ink_secondary) と同色 -->
        <item name="iconTintDefault">@color/ink_secondary</item>
    </style>

    <!--
      Dialog: クリーム地、角丸 16dp。
    -->
    <style name="ThemeOverlay.SimpleMemo.Dialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="colorSurface">@color/surface</item>
        <item name="colorSurfaceContainerHigh">@color/surface</item>
        <item name="colorOnSurface">@color/ink</item>
        <item name="colorOnSurfaceVariant">@color/ink_secondary</item>
        <item name="colorPrimary">@color/accent_sage_dark</item>
        <item name="android:colorBackground">@color/surface</item>
        <item name="android:textColorPrimary">@color/ink</item>
        <item name="android:textColorSecondary">@color/ink_secondary</item>
        <item name="dialogCornerRadius">@dimen/dialog_corner</item>
        <item name="shapeAppearanceMediumComponent">@style/SimpleMemo.ShapeAppearance.Dialog</item>
    </style>

    <!--
      BottomSheet: 上端だけ大きめの角丸 24dp、surface 地。
    -->
    <style name="ThemeOverlay.SimpleMemo.BottomSheet" parent="ThemeOverlay.Material3.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/SimpleMemo.BottomSheet</item>
    </style>

    <style name="SimpleMemo.BottomSheet" parent="Widget.Material3.BottomSheet.Modal">
        <item name="backgroundTint">@color/surface</item>
        <item name="shapeAppearanceOverlay">@style/SimpleMemo.ShapeAppearance.BottomSheet</item>
    </style>

    <style name="SimpleMemo.ShapeAppearance.Dialog" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">@dimen/dialog_corner</item>
    </style>

    <style name="SimpleMemo.ShapeAppearance.BottomSheet" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">@dimen/bottom_sheet_corner</item>
        <item name="cornerSizeTopRight">@dimen/bottom_sheet_corner</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

    <!--
      ウィジェットからのクイック追加 Activity 用 (浮動ダイアログ風カード)。
      windowBackground にクリーム地の角丸 drawable を指定して、独立カードとして見せる。
    -->
    <style name="Theme.SimpleMemo.QuickAdd" parent="Theme.Material3.DayNight.Dialog">
        <item name="android:windowBackground">@drawable/bg_dialog_surface</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowCloseOnTouchOutside">true</item>
        <item name="android:fontFamily">@font/inter_regular</item>
        <item name="colorPrimary">@color/accent_sage</item>
        <item name="colorOnPrimary">@color/accent_sage_text</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/ink</item>
        <item name="android:textColorPrimary">@color/ink</item>
        <item name="android:textColorSecondary">@color/ink_secondary</item>
        <item name="android:textColorHint">@color/graphite</item>
    </style>

</resources>
