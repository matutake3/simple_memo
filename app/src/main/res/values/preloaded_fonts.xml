<?xml version="1.0" encoding="utf-8"?>
<!--
  Pre-declares Downloadable Fonts so the GMS provider fetches and caches
  them at app install / first launch instead of on first display.
-->
<resources>
    <array name="preloaded_fonts" translatable="false">
        <item>@font/inter_light</item>
        <item>@font/inter_regular</item>
        <item>@font/inter_medium</item>
    </array>
</resources>
