<?xml version="1.0" encoding="utf-8"?>
<!-- Same as values/themes.xml — Simple Memo is light-locked for v1. -->
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.SimpleMemo" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent_sage</item>
        <item name="colorOnPrimary">@color/accent_sage_text</item>
        <item name="colorSecondary">@color/accent_blue</item>
        <item name="colorOnSecondary">@color/ink</item>
        <item name="android:colorBackground">@color/paper</item>
        <item name="android:windowBackground">@color/paper</item>
        <item name="android:statusBarColor">@color/paper</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
        <item name="android:navigationBarColor">@color/paper</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">true</item>
        <item name="android:textColorPrimary">@color/ink</item>
        <item name="android:textColorSecondary">@color/ink_secondary</item>
        <item name="android:textColorHint">@color/graphite</item>
        <item name="android:fontFamily">@font/inter_regular</item>
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.SimpleMemo.Dialog</item>
        <item name="bottomSheetDialogTheme">@style/ThemeOverlay.SimpleMemo.BottomSheet</item>
        <item name="colorControlActivated">@color/accent_sage</item>
        <item name="colorControlNormal">@color/ink_secondary</item>
        <item name="colorOnSurface">@color/ink</item>
        <item name="colorSurface">@color/surface</item>
    </style>

</resources>
